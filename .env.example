# Copy to .env and fill in real values. Never commit .env.
#
# LLM provider (Phase 3+, not required for Phase 1)
ANTHROPIC_API_KEY=

# Vibe Prospecting CLI (Phase 2+, not required for Phase 1)
# The agent invokes the `vpai` CLI directly; no key is stored here unless
# the CLI requires one via environment variable. Fill in per vpai docs.
VPAI_API_KEY=

# Comma-separated list of authenticated Vibe accounts/emails used to
# round-robin free-credit limits (Phase 2+).
VIBE_ACCOUNT_EMAILS=

# SQLite database path
LEAD_RADAR_DB_PATH=data/lead_radar.db

# Active data provider: mock | csv | vibe
LEAD_RADAR_PROVIDER=mock
